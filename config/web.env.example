# Runtime configuration for /etc/zunder-zapfe/web.env
# Keep the service bound to loopback: Chromium runs on the same Raspberry Pi.
ZUNDER_ZAPFE_HOST=127.0.0.1
ZUNDER_ZAPFE_PORT=8000
ZUNDER_ZAPFE_DATABASE_URL=sqlite:////var/lib/zunder-zapfe/zunder-zapfe.db
# Path only; the credential itself is created locally and never committed.
ZUNDER_ZAPFE_SUPERADMIN_CREDENTIAL_PATH=/var/lib/zunder-zapfe/superadmin.credential
# Polling-Zugriffe im Normalbetrieb nicht dauerhaft ins Journal schreiben.
ZUNDER_ZAPFE_ACCESS_LOG=0
# Demonstrator calibration. Replace after calibrating the real flow sensor.
ZUNDER_ZAPFE_PULSES_PER_LITER=500
# Alpha defaults for the kiosk; later maintained through the admin UI.
ZUNDER_ZAPFE_STANDARD_PORTIONS_ML=300,500
ZUNDER_ZAPFE_SESSION_TIMEOUT_SECONDS=15
ZUNDER_ZAPFE_ADMIN_SESSION_TIMEOUT_SECONDS=30
# CR-001 alpha values. Calibrate before operating real valve hardware.
ZUNDER_ZAPFE_MANUAL_PRESS_DEBOUNCE_MS=120
ZUNDER_ZAPFE_MANUAL_MAXIMUM_POUR_SECONDS=30
# TEMPORARY DEBUG ONLY: permits UI tests without a physical flow sensor.
# MUST be set to 0 before connecting real valve hardware.
ZUNDER_ZAPFE_DEBUG_DISABLE_FLOW_WATCHDOG=1
# Alpha debugging only. Keep disabled during normal operation.
ZUNDER_ZAPFE_SIMULATE_NFC=0
ZUNDER_ZAPFE_ENABLE_SIMULATOR_API=0
